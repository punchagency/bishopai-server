# Postgres connection string (source of truth for reconciled state)
DATABASE_URL=postgres://bishop:bishop@localhost:5433/bishopai

# HTTP server port
PORT=3000

# Optional: max connections in the pg pool
PG_POOL_MAX=10

# TLS to Postgres. Auto: off for localhost, on (self-signed accepted) for any
# remote DATABASE_URL — matches Heroku/Railway managed Postgres. Force with
# 'true'/'false' if the auto heuristic is wrong for your host.
DATABASE_SSL=

# Log batching — system_events writes are buffered in memory and flushed when
# the buffer reaches LOG_FLUSH_MAX entries or every LOG_FLUSH_INTERVAL_MS,
# whichever comes first. LOG_BUFFER_MAX caps memory if the DB is unreachable.
LOG_FLUSH_MAX=50
LOG_FLUSH_INTERVAL_MS=5000
LOG_BUFFER_MAX=10000

# Max time (ms) to wait for graceful shutdown before forcing exit.
SHUTDOWN_TIMEOUT_MS=10000

# Transcript -> structured session-note extraction (WF1).
# LLM provider is swappable, no code change: google (default, cheapest) | anthropic
LLM_PROVIDER=google
LLM_MAX_TOKENS=4096

# Google Gemini (default) — cheapest per token; gemini-2.5-flash-lite is ample
# for schema-constrained extraction. Set one of GOOGLE_API_KEY / GEMINI_API_KEY.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Anthropic (fallback provider) — set LLM_PROVIDER=anthropic to use.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_EFFORT=low
ANTHROPIC_MAX_TOKENS=8192

# Bee — the backend does NOT call Bee directly. Bee data is E2E-encrypted and
# only readable on Nicole's owner-authenticated machine, so the Electron app's
# Bee courier runs the `bee` CLI there and POSTs conversations to
# POST /webhooks/bee/conversation. This backend just needs the shared secret it
# will verify on that webhook (courier signs with the same value).
#
# Webhook shared secrets — callers send the value in `X-Webhook-Secret` or
# `Authorization: Bearer <secret>`. Leave UNSET in dev to accept unauthenticated
# webhooks (a one-time warning is logged); set in any real deployment. Use
# separate values per source so rotating one doesn't disturb the other.
BEE_WEBHOOK_SECRET=
PB_WEBHOOK_SECRET=
# Practice Better native webhooks: the `plaintextSigningSecret` returned by
# POST /webhooks/subscription. PB signs each delivery with a timestamped HMAC in
# the `PB-Signature` header, verified on POST /webhooks/pb/session.
PB_SIGNING_SECRET=

# Practice Better REST API — OAuth2 client credentials (after beta access).
# src/integrations/pb/ mints a bearer token from these; leave unset until granted.
PB_CLIENT_ID=
PB_CLIENT_SECRET=
PB_API_BASE_URL=https://api.practicebetter.io
# Override only if PB's token endpoint differs from <base>/oauth2/token
PB_OAUTH_TOKEN_URL=

# Google Drive (WF1 — write approved Sheet/Protocol into the client's folder).
# OAuth2 refresh token from Nicole's Google account. Unset = dry-run (logs what
# it would write) so the approve→Drive path works before OAuth is configured.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional parent folder to create per-client folders under
GDRIVE_ROOT_FOLDER_ID=

# Microsoft Graph / Outlook (WF3 re-engagement emails). Unset = dry-run (logs
# what it would send). Set both to send for real.
MS_GRAPH_TOKEN=
MS_GRAPH_SENDER=
MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# Fullscript (WF4 bulk refill orders). Unset = dry-run.
FULLSCRIPT_API_TOKEN=
FULLSCRIPT_API_BASE_URL=https://api.fullscript.com

# QuickBooks Payments (WF2 charging — real money). Unset = dry-run: the whole
# checkout state machine runs but no charge is made. Set both to charge for real.
QB_ACCESS_TOKEN=
QB_REALM_ID=
QB_API_BASE_URL=https://api.intuit.com/quickbooks/v4
# Checkout invoice defaults (cents) when assembling the summary.
CHECKOUT_SESSION_FEE_CENTS=15000
CHECKOUT_SUPPLEMENT_CENTS=2500

# Dashboard auth token lifetime (ms). Default 30 days.
AUTH_TOKEN_TTL_MS=

# In-process scheduler (WF3/WF4 cadences). Off by default; set true to run jobs.
SCHEDULER_ENABLED=false
# Optional cron overrides (node-cron syntax)
CRON_REENGAGEMENT=0 * * * *
CRON_REFILLS=0 3 * * *
