# Postgres connection string (source of truth for reconciled state)
DATABASE_URL=postgres://bishop:bishop@localhost:5433/bishopai

# HTTP server port
PORT=3000

# Optional: max connections in the pg pool
PG_POOL_MAX=10

# TLS to Postgres. Auto: off for localhost, on (self-signed accepted) for any
# remote DATABASE_URL — matches Heroku/Railway managed Postgres. Force with
# 'true'/'false' if the auto heuristic is wrong for your host.
DATABASE_SSL=

# Log batching — system_events writes are buffered in memory and flushed when
# the buffer reaches LOG_FLUSH_MAX entries or every LOG_FLUSH_INTERVAL_MS,
# whichever comes first. LOG_BUFFER_MAX caps memory if the DB is unreachable.
LOG_FLUSH_MAX=50
LOG_FLUSH_INTERVAL_MS=5000
LOG_BUFFER_MAX=10000

# Max time (ms) to wait for graceful shutdown before forcing exit.
SHUTDOWN_TIMEOUT_MS=10000

# Transcript -> structured session-note extraction (WF1).
# LLM provider is swappable, no code change: google (default, cheapest) | anthropic
LLM_PROVIDER=google
LLM_MAX_TOKENS=4096

# Google Gemini (default) — cheapest per token; gemini-2.5-flash-lite is ample
# for schema-constrained extraction. Set one of GOOGLE_API_KEY / GEMINI_API_KEY.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Anthropic (fallback provider) — set LLM_PROVIDER=anthropic to use.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_EFFORT=low
ANTHROPIC_MAX_TOKENS=8192

# Bee — the backend does NOT call Bee directly. Bee data is E2E-encrypted and
# only readable on Nicole's owner-authenticated machine, so the Electron app's
# Bee courier runs the `bee` CLI there and POSTs conversations to
# POST /webhooks/bee/conversation. This backend just needs the shared secret it
# will verify on that webhook (courier signs with the same value).
#
# Webhook shared secrets — callers send the value in `X-Webhook-Secret` or
# `Authorization: Bearer <secret>`. Leave UNSET in dev to accept unauthenticated
# webhooks (a one-time warning is logged); set in any real deployment. Use
# separate values per source so rotating one doesn't disturb the other.
BEE_WEBHOOK_SECRET=
PB_WEBHOOK_SECRET=
# Website contact/booking form (and any inbox-forwarder) → POST /webhooks/lead.
LEAD_WEBHOOK_SECRET=
ANALYTICS_WEBHOOK_SECRET=
# Practice Better native webhooks: the `plaintextSigningSecret` returned by
# POST /webhooks/subscription. PB signs each delivery with a timestamped HMAC in
# the `PB-Signature` header, verified on POST /webhooks/pb/session.
PB_SIGNING_SECRET=

# Practice Better REST API — OAuth2 client credentials (after beta access).
# src/integrations/pb/ mints a bearer token from these; leave unset until granted.
PB_CLIENT_ID=
PB_CLIENT_SECRET=
PB_API_BASE_URL=https://api.practicebetter.io
# Override only if PB's token endpoint differs from <base>/oauth2/token
PB_OAUTH_TOKEN_URL=

# Google Drive (WF1 — write approved Sheet/Protocol into the client's folder).
# OAuth2 refresh token from Nicole's Google account. Unset = dry-run (logs what
# it would write) so the approve→Drive path works before OAuth is configured.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional parent folder to create per-client folders under
GDRIVE_ROOT_FOLDER_ID=

# Microsoft Graph / Outlook (WF3 re-engagement emails).
#
# Preferred: delegated OAuth. Register an app in Microsoft Entra with delegated
# Graph permissions (Mail.Send, Mail.Read, User.Read, offline_access) and set the
# three values below. Nicole then clicks "Connect Outlook" once in Settings and
# consents; the backend captures + stores her refresh token at runtime (never
# from env) and mints access tokens silently thereafter. Unset = dry-run.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# `common` (any account), `organizations`, or a specific tenant id for her M365 org.
MS_TENANT_ID=common
# Where Microsoft redirects back after consent. Must EXACTLY match a redirect URI
# registered on the Entra app. Defaults to <PUBLIC_BASE_URL>/auth/outlook/callback.
PUBLIC_BASE_URL=
OUTLOOK_REDIRECT_URI=
# Override the delegated scopes if needed (space-delimited).
MS_GRAPH_SCOPES=

# Legacy/manual shortcut: a pre-minted bearer token (expires in ~1h, so testing
# only). Set both to send without the OAuth connect flow.
MS_GRAPH_TOKEN=
MS_GRAPH_SENDER=
MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# Fullscript (WF4). OAuth2 authorization-code flow. Run the one-time
# authorize→code→token exchange for the practitioner account, then set the
# refresh token here; the backend mints ~2h access tokens from it. Unset = dry-run.
# Region/env pick the canonical host: us|ca × production(.com)|sandbox(.io).
FULLSCRIPT_REGION=us
FULLSCRIPT_ENV=sandbox
FULLSCRIPT_CLIENT_ID=
FULLSCRIPT_CLIENT_SECRET=
FULLSCRIPT_REFRESH_TOKEN=
# Webhook Secret Key — verifies the Fullscript-Signature (t=..,v1=..) HMAC-SHA256.
FULLSCRIPT_WEBHOOK_SECRET=
# Optional overrides (defaults come from the canonical integration-environments):
FULLSCRIPT_API_BASE_URL=
FULLSCRIPT_OAUTH_TOKEN_URL=
FULLSCRIPT_OAUTH_AUTHORIZE_URL=

# QuickBooks (WF2 — charge via Payments API, read invoice via Accounting API).
# OAuth2: run the one-time authorize→code→token exchange, then seed the refresh
# token here; the backend mints ~1h access tokens and persists rotated refresh
# tokens to integration_state. Unset = dry-run: the whole checkout state machine
# runs but no charge is made. realmId (company id) comes off the auth callback.
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REFRESH_TOKEN=
QB_REALM_ID=
QB_ENV=sandbox
# Optional overrides (defaults resolved from QB_ENV):
QB_PAYMENTS_BASE_URL=
QB_ACCOUNTING_BASE_URL=
QB_OAUTH_TOKEN_URL=
QB_MINOR_VERSION=75
# Checkout invoice defaults (cents) when assembling the summary.
CHECKOUT_SESSION_FEE_CENTS=15000
CHECKOUT_SUPPLEMENT_CENTS=2500

# Dashboard auth token lifetime (ms). Default 30 days.
AUTH_TOKEN_TTL_MS=

# In-process scheduler (WF3/WF4 cadences). Off by default; set true to run jobs.
SCHEDULER_ENABLED=false
# Optional cron overrides (node-cron syntax)
CRON_REENGAGEMENT=0 * * * *
CRON_REFILLS=0 3 * * *
CRON_MAINTENANCE=30 3 * * *
CRON_FIRST_APPT=45 3 * * *
CRON_INBOX_POLL=*/5 * * * *
CRON_RECONCILE=*/5 * * * *
CRON_REFILL_REMINDERS=15 3 * * *
# WF1: require recorded consent before capture is processed (opt-in; off by default).
REQUIRE_RECORDING_CONSENT=false
# Days since a client's last completed session before they count as maintenance-phase.
MAINTENANCE_GAP_DAYS=90
# Days after a client's only session before the first-appointment conversion cadence
# starts (gives them time to rebook on their own first). 3 is aggressive; a real
# deployment may prefer a higher value so mid-review clients aren't nudged too soon.
FIRST_APPT_AFTER_DAYS=3
