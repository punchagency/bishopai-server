{
  "name": "bishopai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Innerlume Healing automation backend — correlation engine + checkout state machine",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "demo:server": "DEMO_OUTPUT_DIR=./demo-output tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "seed": "tsx src/db/seed.ts",
    "demo:templates": "tsx scripts/demo-templates.mts",
    "google-auth": "node scripts/google-auth.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "qb-auth": "node scripts/qb-auth.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "@google/genai": "^2.10.0",
    "docxtemplater": "^3.69.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "groq-sdk": "^1.3.0",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "pizzip": "^3.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
